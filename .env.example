# Postgres connection string (Neon or local). SQLAlchemy async driver prefix required.
DATABASE_URL=postgresql+asyncpg://user:pass@ep-xxx.neon.tech/riskguard?ssl=require

# AWS region for Bedrock. Credentials come from the standard AWS chain
# (profile, env vars, or IAM role) — never hardcode keys here or anywhere else.
AWS_REGION=us-east-1

# Bedrock model ID. Newer/larger models require an inference-profile ID
# (region-prefixed, e.g. "us.anthropic....") rather than the bare model ID —
# check `aws bedrock list-inference-profiles` if you get a ValidationException
# about on-demand throughput. Some flagship models (e.g. claude-sonnet-5) also
# require extra AWS account approval before InvokeModel will succeed; verify
# with a test `aws bedrock-runtime invoke-model` call before deploying.
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-5-20250929-v1:0

# Directory containing the trained model artifact (model.joblib, metrics.json,
# threshold.json, feature_names.json). Relative to the repo root.
MODEL_ARTIFACT_DIR=ml/artifacts/v1

# Raw default-probability cut above which a remediation case + agent workflow
# are triggered. Independent of the F1-optimal classification threshold.
RISK_TRIGGER_THRESHOLD=0.70

# "memory" for local/demo runs (LangGraph MemorySaver — lost on process restart).
# "postgres" for production (langgraph-checkpoint-postgres against the same
# Neon database as DATABASE_URL).
CHECKPOINTER_BACKEND=memory

LOG_LEVEL=INFO
